output=DP-3
anchor=top-right
layer=overlay

font=JetBrainsMono Nerd Font 10

background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa

border-size=2
border-radius=8

padding=10
margin=8
width=320

icons=1
icon-path=/usr/share/icons/Papirus
max-icon-size=20

format=<b>%s</b>\n%b
markup=1
text-alignment=left

default-timeout=5000
ignore-timeout=1

max-visible=5
sort=-time

[urgency=low]
border-color=#6c7086
default-timeout=3000

[urgency=normal]
border-color=#89b4fa
default-timeout=5000

[urgency=critical]
border-color=#f38ba8
background-color=#3b1f2b
default-timeout=5000

[app-name=wezterm urgency=critical]
border-color=#89b4fa
background-color=#1e1e2e
default-timeout=5000

[app-name=wezterm urgency=critical]
border-color=#89b4fa
background-color=#1e1e2e
default-timeout=5000
