{
  "layer": "top",
  "position": "top",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock", "custom/pomodoro"],
  "modules-right": ["pulseaudio", "network", "cpu", "memory"],

  "custom/pomodoro": {
	  "format": "{}",
	  "return-type": "json",
  	"exec": "waybar-module-pomodoro -w 50 -s 10 -30 --autob --autow",
	  "on-click": "waybar-module-pomodoro toggle",
	  "on-click-right": "waybar-module-pomodoro reset",
  },

  "network": {
    "format": "{icon}",
    "format-wifi": " ",
    "format-ethernet": " ",
    "format-disconnected": "⚠ Disconnected",
    "tooltip": false
  },

  "clock": {
    "format": "{:%d.%m.%y %H:%M}",
    "format-alt": "{:%a %d %b %H:%M}",
    "format-alt-click": "click-left",
    "tooltip": false
  },

  "cpu": {
    "format": "CPU {usage}%"
  },

  "memory": {
    "format": "RAM {used:0.1f}G"
  },

 "pulseaudio": {
  "format": "{icon} {volume}%",
  "format-bluetooth": "{icon}  {volume}%",
  "format-muted": " Muted",
  "format-icons": {
    "headphone": "",
    "default": ["", "", ""]
  },
  "scroll-step": 2,
  "on-click": "pamixer -t",
  "on-click-right": "pactl set-default-sink $((s=$(pactl list short sinks | sed -e 's:^[0-9]\\+\\s\\+::' | grep -oP '^\\S+'); echo \"$s\"; echo \"$s\") | grep -F $(pactl get-default-sink) -m1 -A1 | tail -1)",
  "on-scroll-up": "pamixer -i 2",
  "on-scroll-down": "pamixer -d 2"
  },

  "hyprland/workspaces": {
    "on-click": "activate",
    "tooltip": false
  }
}

